# Portfolio Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Email Configuration (Required for contact form)
EMAIL_USER=your.email@gmail.com
EMAIL_PASSWORD=your_app_password
RECIPIENT_EMAIL=your.email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Telegram Bot (Optional - for instant notifications)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# WhatsApp Business API (Optional - for WhatsApp notifications)
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Notion Integration (Optional - for lead storage)
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_database_id

# Google Sheets (Optional - for lead storage)
GOOGLE_SHEETS_WEBHOOK_URL=your_google_apps_script_webhook_url

# Database (Already configured - DO NOT MODIFY)
MONGO_URL=mongodb://localhost:27017
DB_NAME=portfolio_db