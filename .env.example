# ============================================================
# Portfolio aissabelkoussa.fr — variables d'environnement
# Copier ce fichier en .env.local et remplir les vraies valeurs
# ============================================================

# --- MongoDB ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=portfolio

# --- SMTP Gmail (canal email de fallback) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
RECIPIENT_EMAIL=contact@aissabelkoussa.fr
EMAIL_FALLBACK_PROVIDER=formsubmit

# --- Resend (canal email principal pour notif contact + auto-reply + séquences) ---
# Dashboard : https://resend.com/api-keys
# Domaine aissabelkoussa.fr doit être vérifié dans Resend (DNS SPF + DKIM)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- Cloudflare Turnstile (anti-bot, en amont du spam check custom) ---
# Dashboard : https://dash.cloudflare.com/?to=/:account/turnstile
# Créer un site Turnstile pour aissabelkoussa.fr en mode "Managed"
# La site key est publique, le secret reste backend uniquement
TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxx_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx

# --- Notifications (optionnel) ---
ADMIN_WHATSAPP_NUMBER=33XXXXXXXXX
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Auth admin (si dashboard activé) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=generate-a-strong-random-secret

# ============================================================
# Clés de TEST Cloudflare Turnstile (pour dev local uniquement)
# Documentation : https://developers.cloudflare.com/turnstile/troubleshooting/testing/
# ============================================================
# Always passes : 1x00000000000000000000AA (site) + 1x0000000000000000000000000000000AA (secret)
# Always blocks : 2x00000000000000000000AB (site) + 2x0000000000000000000000000000000AA (secret)
# Forces challenge : 3x00000000000000000000FF (site) + 1x0000000000000000000000000000000AA (secret)
